---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const organizers = [
  {
    name: 'Chris Rouse',
    photo: '/images/organizer-chris.jpg',
    bio: 'Chris has been interested in effective giving for over a decade and signed the 10% pledge in 2021. He has been organising effective giving events in London since 2023. By day he\'s a systems engineer in telecoms and enjoys a good bike ride.',
  },
  {
    name: 'Lorenzo Fonce-Pong',
    photo: null,
    bio: 'Bio coming soon.',
  },
];

const roles = [
  {
    title: 'Ambassador',
    time: 'No time outside of events',
    description: 'On the day support — arrives early and helps with practicalities like collecting food, name badges, welcoming attendees, and engaging newcomers.',
  },
  {
    title: 'Event Logistics',
    time: '1–2 hrs per event',
    description: 'Securing venues, arranging catering, and handling social advertising to make each event happen.',
  },
  {
    title: 'Full Event',
    time: '4 hrs per event',
    description: 'Taking ownership of an event from idea through to event page and programming.',
  },
];
---

<BaseLayout
  title="Get Involved | London Effective Giving Community"
  description="Meet the organisers, volunteer with us, or get in touch with the London Effective Giving Community."
>
  <Navbar subpage={true} />

  <main id="main-content">

    <!-- Header -->
    <div class="bg-primary-950 pt-32 pb-16 text-center">
      <h1 class="font-display text-4xl sm:text-5xl text-white">Get Involved</h1>
      <p class="mt-5 text-lg text-white/60 max-w-xl mx-auto px-5">
        We're a small volunteer team excited about growing effective giving in London.
      </p>
    </div>

    <!-- Subscribe -->
    <section class="bg-white py-20 sm:py-24 border-b border-slate-100">
      <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center">
        <span class="text-sm font-semibold text-accent-500 uppercase tracking-widest">Stay in the loop</span>
        <h2 class="mt-4 font-display text-3xl sm:text-4xl text-slate-900">Come to a future event</h2>
        <p class="mt-5 text-lg text-slate-600 leading-relaxed">
          Subscribe to our calendar and get notified whenever we announce a new event — socials, workshops, co-working sessions and more.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="https://luma.com/london-effective-giving-community#:~:text=Sign%20In-,Subscribe,-London%20Effective%20Giving"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-500 hover:bg-accent-400 text-white font-semibold transition-all duration-200 shadow-md shadow-accent-500/20 hover:shadow-lg hover:shadow-accent-500/30 hover:-translate-y-px"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            Subscribe to future events
          </a>
          <a
            href="https://luma.com/calendar/cal-y1kIXdGOliIqTu8"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-slate-200 bg-white text-slate-600 hover:border-primary-300 hover:text-primary-700 font-medium text-sm transition-all duration-200 shadow-sm hover:shadow"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Browse upcoming events
          </a>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="bg-slate-50 py-20 sm:py-28">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-12">
        <div class="text-center mb-14">
          <span class="text-sm font-semibold text-accent-500 uppercase tracking-widest">The organisers</span>
          <h2 class="mt-4 font-display text-3xl sm:text-4xl text-slate-900">Who we are</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
          {organizers.map((person) => (
            <div class="flex flex-col items-center text-center">
              <div class="w-36 h-36 rounded-full overflow-hidden bg-slate-100 ring-4 ring-white shadow-lg shrink-0">
                {person.photo ? (
                  <img
                    src={person.photo}
                    alt={person.name}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-primary-50">
                    <svg class="w-16 h-16 text-primary-200" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                  </div>
                )}
              </div>
              <h3 class="mt-5 font-display text-2xl text-slate-900">{person.name}</h3>
              <p class="mt-1 text-sm font-semibold text-accent-500 uppercase tracking-wider">Co-organiser</p>
              <p class="mt-4 text-slate-600 leading-relaxed">{person.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Volunteer -->
    <section class="bg-white py-20 sm:py-28">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-12">
        <div class="text-center mb-14">
          <span class="text-sm font-semibold text-accent-500 uppercase tracking-widest">Volunteer</span>
          <h2 class="mt-4 font-display text-3xl sm:text-4xl text-slate-900">Join the team</h2>
          <p class="mt-5 text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">
            We'd love more hands. Whatever time you have to spare, there's a role that fits.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {roles.map((role) => (
            <div class="bg-slate-50 rounded-2xl p-7 border border-slate-100">
              <h3 class="font-display text-xl text-slate-900">{role.title}</h3>
              <span class="inline-block mt-2 text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">
                {role.time}
              </span>
              <p class="mt-4 text-slate-600 leading-relaxed text-sm">{role.description}</p>
            </div>
          ))}
        </div>
        <p class="mt-10 text-center text-slate-500 text-sm">
          Interested? Drop us a message below and let us know what sounds right for you.
        </p>
      </div>
    </section>

    <!-- Contact -->
    <ContactForm />

  </main>

  <Footer subpage={true} />
</BaseLayout>
