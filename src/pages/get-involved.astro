---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const organizers = [
  {
    name: 'Chris Rouse',
    photo: '/images/organizer-chris.jpg',
    bio: 'Chris has been interested in effective giving for over a decade and signed the 🔸 10% pledge in 2021. He has been organising effective giving events in London since 2023. By day he\'s a systems engineer in telecoms and enjoys a good bike ride.',
  },
  {
    name: 'Lorenzo Fonce-Pong',
    photo: '/images/organizer-lorenzo.jpg',
    bio: 'Lorenzo is a 🔸 10% Pledger on a mission to become one of Earth\'s best advocates for effective giving. Reach out for a link to his personal EG strategy doc! He has a day job as a strategy and operations manager at Amazon, and cares about how professionals can use their charitable giving and influence to do more good.',
  },
];

const roles = [
  {
    title: 'Ambassador',
    time: 'No time outside of events',
    description: 'On the day support — arrives early and helps with practicalities like collecting food, name badges, welcoming attendees, and engaging newcomers.',
  },
  {
    title: 'Event Logistics',
    time: '1–2 hrs per event',
    description: 'Securing venues, arranging catering, and handling social advertising to make each event happen.',
  },
  {
    title: 'Full Event',
    time: '4+ hrs per event',
    description: 'Taking ownership of an event from idea through to event page and programming.',
  },
];
---

<BaseLayout
  title="Get Involved | London Effective Giving Community"
  description="Meet the organisers, volunteer with us, or get in touch with the London Effective Giving Community."
>
  <Navbar subpage={true} />

  <main id="main-content">

    <!-- Header -->
    <div class="bg-primary-950 pt-32 pb-16 text-center">
      <h1 class="font-display text-4xl sm:text-5xl text-white">Get Involved</h1>
      <p class="mt-5 text-lg text-white/60 max-w-xl mx-auto px-5">
        We're a small volunteer team excited about growing effective giving in London.
      </p>
    </div>

    <!-- Subscribe -->
    <section class="bg-white py-14 sm:py-16 border-b border-slate-100">
      <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center">
        <h2 class="font-display text-3xl sm:text-4xl text-slate-900">Stay in the loop</h2>
        <div class="mt-7">
          <a
            href="https://luma.com/london-effective-giving-community#:~:text=Sign%20In-,Subscribe,-London%20Effective%20Giving"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-500 hover:bg-accent-400 text-white font-semibold transition-all duration-200 shadow-md shadow-accent-500/20 hover:shadow-lg hover:shadow-accent-500/30 hover:-translate-y-px"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            Subscribe to future events
          </a>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="bg-slate-50 py-20 sm:py-28">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-12">
        <h2 class="font-display text-3xl sm:text-4xl text-slate-900 text-center mb-14">The team</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
          {organizers.map((person) => (
            <div class="flex flex-col items-center text-center">
              <div class="w-44 h-44 rounded-full overflow-hidden bg-slate-100 ring-4 ring-white shadow-lg shrink-0">
                {person.photo ? (
                  <img
                    src={person.photo}
                    alt={person.name}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-primary-50">
                    <svg class="w-20 h-20 text-primary-200" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                  </div>
                )}
              </div>
              <h3 class="mt-6 font-display text-2xl text-slate-900">{person.name}</h3>
              <p class="mt-1 text-sm font-semibold text-accent-500 uppercase tracking-wider">Co-organiser</p>
              <p class="mt-4 text-slate-600 leading-relaxed">{person.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Volunteer -->
    <section class="bg-white py-20 sm:py-28">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-12">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl sm:text-4xl text-slate-900">Join the team</h2>
          <p class="mt-4 text-lg text-slate-500">We'd love more hands. If you're interested in helping out with any of the following, please get in touch with the contact form linked below.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {roles.map((role) => (
            <div class="bg-white rounded-2xl p-7 text-center ring-1 ring-slate-200/80 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
              <h3 class="font-display text-xl text-slate-900">{role.title}</h3>
              <span class="inline-block mt-3 text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1.5 rounded-full">
                {role.time}
              </span>
              <p class="mt-4 text-slate-500 leading-relaxed text-sm">{role.description}</p>
            </div>
          ))}
        </div>
        <p class="mt-10 text-center text-sm text-slate-400">
          If you're interested, <a href="/contact" class="text-primary-600 hover:text-primary-700 font-medium underline underline-offset-2 transition-colors">drop us a message below.</a>
        </p>
      </div>
    </section>

    <!-- Contact -->
    <section class="py-20 sm:py-28 bg-slate-50">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">

          <!-- Get in touch -->
          <div class="flex flex-col justify-center">
            <div class="bg-primary-950 rounded-2xl p-10 text-center">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-accent-500/20 mb-6">
                <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <h2 class="font-display text-2xl sm:text-3xl text-white">Get in touch</h2>
              <p class="mt-4 text-white/60 leading-relaxed">
                Have a question or want to get involved? We'd love to hear from you.
              </p>
              <a
                href="/contact"
                class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-500 hover:bg-accent-400 text-white font-semibold transition-all duration-200 shadow-md shadow-accent-500/20 hover:shadow-lg hover:shadow-accent-500/30 hover:-translate-y-px"
              >
                Send us a message
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <p class="mt-4 text-white/30 text-xs">We'll get back to you</p>
            </div>
          </div>

          <!-- Submit an event idea -->
          <div class="flex flex-col justify-center">
            <div class="bg-primary-950 rounded-2xl p-10 text-center">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-accent-500/20 mb-6">
                <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </div>
              <h2 class="font-display text-2xl sm:text-3xl text-white">Got an event idea?</h2>
              <p class="mt-4 text-white/60 leading-relaxed">
                Have a topic, format, or speaker in mind? We'd love to hear it.
              </p>
              <a
                href="https://docs.google.com/forms/d/e/1FAIpQLSea50kmW7YYW5bCWd1Uyn-po8_bOOa1r17fvFWmmdok10kBQA/viewform?usp=publish-editor"
                class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-500 hover:bg-accent-400 text-white font-semibold transition-all duration-200 shadow-md shadow-accent-500/20 hover:shadow-lg hover:shadow-accent-500/30 hover:-translate-y-px"
              >
                Submit an event idea
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <p class="mt-4 text-white/30 text-xs">Opens a short form</p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer subpage={true} />
</BaseLayout>
