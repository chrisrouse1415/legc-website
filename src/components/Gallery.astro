---
const images = [
  { src: '/images/event-2.jpg',  alt: 'Meetup at Newspeak House' },
  { src: '/images/event-11.jpg', alt: 'Social at Seven Dials Market' },
  { src: '/images/event-1.jpg',  alt: 'Summer Picnic' },
  { src: '/images/event-10.jpg', alt: 'Denise Melchin on Earning to Give' },
  { src: '/images/event-8.jpg',  alt: 'Chris Rouse on the future of EA & giving' },
  { src: '/images/event-9.jpg',  alt: 'Member with a GWWC pledge certificate' },
  { src: '/images/event-3.jpg',  alt: 'Summer Picnic' },
  { src: '/images/event-12.jpg', alt: 'Quarterly Co-working session' },
  { src: '/images/event-4.jpg',  alt: 'Social at Newspeak House' },
  { src: '/images/event-6.jpg',  alt: 'Pub Social' },
  { src: '/images/event-5.jpg',  alt: 'Pub Social' },
  { src: '/images/event-13.jpg', alt: 'Talk on founding and funding effective charities' },
  { src: '/images/event-14.jpg', alt: 'Effective animal charities event' },
  { src: '/images/event-15.jpg', alt: 'Effective giving debate' },
  { src: '/images/event-16.jpg', alt: 'Effective giving debate' },
  { src: '/images/event-17.jpg', alt: 'Effective giving debate' },
];
---

<section id="gallery" class="py-24 sm:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <h2 class="font-display text-4xl sm:text-5xl text-slate-900 leading-tight text-center mb-12">
      Past Events
    </h2>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 lg:gap-5">
      {[...images].reverse().map((image) => (
        <div class="group relative overflow-hidden rounded-2xl shadow-sm aspect-[4/3]">
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div class="absolute inset-x-0 bottom-0 px-4 py-4
                      bg-gradient-to-t from-black/75 via-black/40 to-transparent
                      translate-y-full group-hover:translate-y-0
                      transition-transform duration-300 ease-out">
            <p class="text-white text-sm font-medium leading-snug tracking-wide">
              {image.alt}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
