#!/bin/sh
# Detect staged images and offer to compress them before committing.

STAGED_IMAGES=$(git diff --cached --name-only | grep -iE '\.(jpg|jpeg|png|webp)$')

if [ -z "$STAGED_IMAGES" ]; then
  exit 0
fi

echo ""
echo "Staged images:"
for img in $STAGED_IMAGES; do
  echo "  $img"
done
echo ""

# Only prompt if we have an interactive terminal
if [ -t 1 ] && [ -c /dev/tty ]; then
  exec < /dev/tty
  printf "Compress images before committing? [y/N] "
  read CONFIRM
  echo ""
else
  echo "No interactive terminal — skipping compression prompt."
  echo ""
  exit 0
fi

case "$CONFIRM" in
  y|Y)
    node scripts/compress-staged-images.mjs $STAGED_IMAGES
    for img in $STAGED_IMAGES; do
      git add "$img"
    done
    echo ""
    ;;
  *)
    echo "Skipping compression."
    echo ""
    ;;
esac
